<!DOCTYPE html>
<html>

<head>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-blue-300 text-white">

<h1 class="text-2xl text-red-300">Create Anime Post</h1>

<form class="bg-pink-200 flex flex-col gap-4" action="/create" method="POST" enctype="multipart/form-data">

<input class="mt-5" name="title" placeholder="Anime title"/>

<textarea class="mt-5" name="content"></textarea>

<input class="mt-5" type="file" name="image"/>

<button class="px-4 py-2 mt-5 rounded bg-blue-500">Create</button>

</form>

</body>
