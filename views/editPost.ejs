<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
</head>
<body class="bg-black text-white p-10">
   <div class="max-w-2xl mx-auto bg-gray-900 p-6 rounded">
    <h1 class="text-3xl mb-6">Edit Post</h1>

    <form action="/edit/<%= post._id %>" method="POST" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-bold mb-2">Title</label>
        <input type="text" name="title" value="<%= post.title %>" class="w-full p-2 rounded bg-gray-800 text-white border border-gray-700" required>
      </div>

      <div>
        <label class="block text-sm font-bold mb-2">Content</label>
        <textarea name="content" class="w-full p-2 rounded bg-gray-800 text-white border border-gray-700 h-40" required><%= post.content %></textarea>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="px-4 py-2 bg-blue-500 rounded hover:bg-blue-600">Update Post</button>
        <a href="/post/<%= post._id %>" class="px-4 py-2 bg-gray-700 rounded hover:bg-gray-600">Cancel</a>
        <a href="/delete/<%= post._id %>" class="px-4 py-2 bg-red-500 rounded hover:bg-red-600">Delete</a>
      </div>
    </form>
   </div>

</body>
</html>