<!DOCTYPE html>
<html>

<head>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-black text-white">

<div class="bg-gray-900 p-5 shadow">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <h1 class="text-4xl">Anime Blog 🎌</h1>

    <div class="flex gap-4 items-center">
      <% if (user) { %>
        <span class="text-gray-300">Welcome <%= user.name %></span>
        <a href="/create" class="px-4 py-2 bg-blue-600 rounded hover:bg-blue-700">+ Create Post</a>
        <a href="/logout" class="px-4 py-2 text-red-400 hover:text-red-300">Logout</a>
      <% } else { %>
        <a href="/login" class="px-4 py-2 bg-blue-600 rounded hover:bg-blue-700">Login</a>
        <a href="/register" class="px-4 py-2 bg-gray-700 rounded hover:bg-gray-600">Register</a>
      <% } %>
    </div>
  </div>
</div>

<div class="grid grid-cols-3 gap-5 p-10 max-w-7xl mx-auto">

<% posts.forEach(post => { %>

<div class="bg-gray-900 p-3 rounded hover:bg-gray-800 transition">

<img src="/<%= post.image %>" class="h-40 w-full object-cover rounded mb-3">

<h2 class="text-xl mt-2 font-bold">

<%= post.title %>

</h2>

<p class="text-gray-400 text-sm mb-3">

By <%= post.user.name %>

</p>

<div class="flex gap-2 flex-wrap">
  <a href="/post/<%= post._id %>" class="px-3 py-1 bg-blue-600 rounded text-sm hover:bg-blue-700">
    Read More
  </a>
  <a href="/edit/<%= post._id %>" class="px-3 py-1 bg-yellow-600 rounded text-sm hover:bg-yellow-700">
    Edit
  </a>
  <a href="/delete/<%= post._id %>" class="px-3 py-1 bg-red-600 rounded text-sm hover:bg-red-700">
    Delete
  </a>
  <a href="/like/<%= post._id %>" class="px-3 py-1 bg-pink-600 rounded text-sm hover:bg-pink-700">
    ❤️ <%= post.likes && post.likes.length > 0 ? post.likes.length : 0 %>
  </a>
</div>


</div>

<% }) %>

</div>


</body>

</html>
