<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title></title>
</head>
<body class="bg-pink-200 text-gray">
    

<div class="flex justify-center items-center min-h-screen">
  
<form class="bg-gray-200 w-80 p-6 shadow rounded" action="/auth/register" method="POST">
  <h2 class="text-2xl red p-2">Register</h2>
<input class="p-2 rounded w-full mb-3" name="name" placeholder="Name" />

<input class="p-2 rounded w-full mb-3" name="email" placeholder="Email" />

<input class="p-2 rounded w-full mb-3" name="password" placeholder="Password" />

<button class="px-3 py-2 rounded bg-pink-500">Register</button>
<a href="/auth/login" class="text-blue-700 text-xl ml-15 underline">Login</a>
</form>

</div>
</body>
</html>