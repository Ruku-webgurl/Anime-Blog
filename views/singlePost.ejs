<!DOCTYPE html>
<html>

<head>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-black text-white p-10">

<div class="max-w-4xl mx-auto">

<h1 class="text-4xl font-bold mb-5">

<%= post.title %>

</h1>


<img src="/<%= post.image %>" class="mt-5 rounded w-full max-h-96 object-cover">


<p class="mt-5 text-lg leading-relaxed">

<%= post.content %>

</p>


<p class="mt-5 text-gray-400 text-xl">

Created by <%= post.user.name %>

</p>

<div class="mt-8 flex gap-3 mb-10">
  <a href="/edit/<%= post._id %>" class="px-4 py-2 bg-blue-500 rounded hover:bg-blue-600">Edit</a>
  <a href="/delete/<%= post._id %>" class="px-4 py-2 bg-red-500 rounded hover:bg-red-600">Delete</a>
  <a href="/like/<%= post._id %>" class="px-4 py-2 bg-pink-600 rounded hover:bg-pink-700">❤️ <%= post.likes && post.likes.length > 0 ? post.likes.length : 0 %></a>
  <a href="/" class="px-4 py-2 bg-gray-700 rounded hover:bg-gray-600">Back</a>
</div>

<!-- Comments Section -->
<div class="mt-10 border-t border-gray-700 pt-8">
  <h2 class="text-2xl font-bold mb-5">Comments</h2>

  <!-- Comment Form -->
  <form action="/comment/<%= post._id %>" method="POST" class="mb-8">
    <textarea name="text" class="w-full p-3 rounded bg-gray-800 text-white border border-gray-700 mb-3 h-24" placeholder="Write a comment..." required></textarea>
    <button type="submit" class="px-4 py-2 bg-blue-600 rounded hover:bg-blue-700">Post Comment</button>
  </form>

  <!-- Display Comments -->
  <div class="space-y-4">
    <% if (post.comments && post.comments.length > 0) { %>
      <% post.comments.forEach(comment => { %>
        <div class="bg-gray-900 p-4 rounded border border-gray-700">
          <p class="text-gray-400 text-sm mb-2"><strong><%= comment.user.name %></strong></p>
          <p class="mb-3"><%= comment.text %></p>
          <a href="/deleteComment/<%= post._id %>/<%= comment._id %>" class="text-red-500 text-sm hover:text-red-400">Delete</a>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-400">No comments yet. Be the first to comment!</p>
    <% } %>
  </div>
</div>

</div>

</body>

</html>
